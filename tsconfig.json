{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "module": "Node16",
    "allowImportingTsExtensions": true,
    "target": "esnext",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true
    
  }
}
